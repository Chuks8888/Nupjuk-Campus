{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "rootDir": "src",
    "outDir": "dist",

    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",

    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*.ts", "old-routes/attachments.ts", "old-routes/boards.ts", "old-routes/calendar.ts", "old-routes/comments.ts", "old-routes/coursePosts.ts"],
  "exclude": ["node_modules", "dist"]
}
