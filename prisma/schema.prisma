generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  studentId    String?  @unique
  kaistEmail   String   @unique
  displayName  String?
  passwordHash String
  createdAt    DateTime @default(now())

  enrollments             Enrollment[]
  posts                   Post[]
  comments                Comment[]
  assignmentStatuses      UserAssignmentStatus[]
  personalEvents          PersonalEvent[]
  createdMeetings         MeetingEvent[]
  meetingParticipants     MeetingParticipant[]
  meetingAvailabilities   MeetingAvailability[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
}

model Course {
  id           Int      @id @default(autoincrement())
  courseCode   String   @unique
  courseName   String   @unique
  semester     String
  klmsCourseId String   @unique
  createdAt    DateTime @default(now())

  enrollments             Enrollment[]
  boards                  Board[]
  assignments             Assignment[]
  meetings                MeetingEvent[]
  notificationPreferences NotificationPreference[]
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  userId     Int
  courseId   Int
  verifiedAt DateTime
  validUntil DateTime
  status     String   @default("active")
  role       String   @default("student")

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Board {
  id        Int      @id @default(autoincrement())
  courseId  Int      @unique
  introText String?
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id])
  posts  Post[]
}

model Post {
  id        Int          @id @default(autoincrement())
  boardId   Int
  authorId  Int
  title     String
  body      String
  category  PostCategory @default(GENERAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  board       Board        @relation(fields: [boardId], references: [id])
  author      User         @relation(fields: [authorId], references: [id])
  comments    Comment[]
  attachments Attachment[]
}

enum PostCategory {
  GENERAL
  QUESTION
  ASSIGNMENT
  EXAM
  PROJECT
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  authorId  Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])
}

model Attachment {
  id             Int       @id @default(autoincrement())
  postId         Int
  fileName       String
  fileUrl        String
  fileSize       Int?
  fileExtension  String?
  storageBackend String    @default("server")
  uploadedAt     DateTime  @default(now())
  expiresAt      DateTime?

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Assignment {
  id               Int       @id @default(autoincrement())
  courseId         Int
  title            String
  dueDate          DateTime?
  description      String?
  source           String    @default("klms_synced")
  klmsAssignmentId String

  userStatuses UserAssignmentStatus[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  assignmentUrl String   @unique

  course Course @relation(fields: [courseId], references: [id])

  @@unique([courseId, klmsAssignmentId])
}

model UserAssignmentStatus {
  id           Int @id @default(autoincrement())
  userId       Int
  assignmentId Int

  klmsSubmissionStatus String?
  klmsTimingStatus     String    @default("on_time")
  userCompletionStatus String    @default("todo")
  completedAt          DateTime?

  user       User       @relation(fields: [userId], references: [id])
  assignment Assignment @relation(fields: [assignmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, assignmentId])
}

model PersonalEvent {
  id          Int      @id @default(autoincrement())
  userId      Int
  title       String
  startTime   DateTime
  endTime     DateTime
  description String?
  status      String   @default("todo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model MeetingEvent {
  id                 Int       @id @default(autoincrement())
  courseId           Int
  creatorId          Int
  title              String
  description        String?
  dateRangeStart     DateTime
  dateRangeEnd       DateTime
  timeRangeStart     String
  timeRangeEnd       String
  finalizedStartTime DateTime?
  finalizedEndTime   DateTime?
  status             String    @default("open")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  course         Course                @relation(fields: [courseId], references: [id])
  creator        User                  @relation(fields: [creatorId], references: [id])
  participants   MeetingParticipant[]
  availabilities MeetingAvailability[]
}

model MeetingParticipant {
  id             Int      @id @default(autoincrement())
  meetingEventId Int
  userId         Int
  joinedAt       DateTime @default(now())

  meetingEvent MeetingEvent @relation(fields: [meetingEventId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([meetingEventId, userId])
}

model MeetingAvailability {
  meetingEventId Int
  userId         Int
  availableSlots Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  meetingEvent MeetingEvent @relation(fields: [meetingEventId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@id([meetingEventId, userId])
}

model Notification {
  id              Int      @id @default(autoincrement())
  userId          Int
  type            String
  content         String
  deliveryChannel String   @default("in_app")
  targetType      String?
  targetId        Int?
  targetUrl       String?
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model NotificationPreference {
  id                     Int     @id @default(autoincrement())
  userId                 Int
  courseId               Int?
  postCommentEnabled     Boolean @default(true)
  deadlineEnabled        Boolean @default(true)
  meetingEnabled         Boolean @default(true)
  emailEnabled           Boolean @default(false)
  deadlineReminderTiming Json?

  user   User    @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
}

model EmailVerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
